# Firebase 콘솔 > 프로젝트 설정 > 내 앱(웹 앱) > SDK 설정 및 구성 에서 복사 (admin/.env와 같은 값)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# 네이버 클라우드 플랫폼 > AI·NAVER API > Maps 에서 발급받은 Client ID
NAVER_MAP_CLIENT_ID=

# 기상청 API허브 (단기예보/초단기실황)
KMA_API_KEY=

# 한국천문연구원 (일출일몰/월령 등)
KASI_API_KEY=

# 한국관광공사 TourAPI
TOUR_API_KEY=

# 에어코리아 대기질 정보
AIRKOREA_API_KEY=
